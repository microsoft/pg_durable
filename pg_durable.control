comment = 'pg_durable: SQL-native durable orchestrations for PostgreSQL'
default_version = '@CARGO_VERSION@'
module_pathname = 'pg_durable'
schema = pg_catalog
# pgrx's control-file parser requires `relocatable` and `superuser` to be
# present explicitly (they are otherwise PostgreSQL defaults).
relocatable = false
superuser = true